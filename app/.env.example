# Custom Solana RPC endpoints used by the frontend.
# The public clusterApiUrl endpoint is heavily rate-limited (HTTP 429),
# so use a dedicated devnet RPC from a provider such as Helius, QuickNode,
# Alchemy, or Triton.
#
# Must be prefixed with NEXT_PUBLIC_ so they are available in the browser.

# HTTP RPC endpoint (used by the wallet ConnectionProvider and utils/anchor.ts)
NEXT_PUBLIC_RPC=https://api.devnet.solana.com

# WebSocket RPC endpoint (used for subscriptions in utils/anchor.ts)
NEXT_PUBLIC_WSS_RPC=wss://api.devnet.solana.com

# Metaplex Read API (DAS) endpoint, e.g. a Helius devnet URL with your api-key.
# Falls back to the public devnet RPC if unset. Keep any api-key out of source.
NEXT_PUBLIC_READAPI_RPC=https://api.devnet.solana.com
